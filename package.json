{
  "name": "get.rpath.dev",
  "version": "1.0.0",
  "description": "Hosted installer and uninstaller script server for rpath.",
  "type": "module",
  "scripts": {
    "check": "bun build api/index.js --target=node --outdir=.check",
    "dev": "node src/index.js",
    "start": "node src/index.js",
    "format": "prettier --write .",
    "test": "bun run check"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "prettier": "^3.9.4"
  }
}
